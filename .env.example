# ============================ 示例环境配置 ============================ #
# 复制为 .env 后填入真实值。真实 .env 只在服务器，绝不进 Git 仓库。
# 容器内路径以 /data 为基准（compose 将宿主 ./data 挂载到容器 /data）。

# ---- 外部 LLM API（OpenAI 兼容接口；不在本机推理）----
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ---- Embedding API（默认阿里云百炼原生格式；也可切到 openai）----
EMBEDDING_PROVIDER=dashscope
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
# 可选：OpenAI 兼容 embedding 可填维度；百炼原生也支持 dimension
# EMBEDDING_DIMENSIONS=1024
# 百炼原生 embedding 使用 query/document 区分；索引默认 document，检索 query 由后端自动切换
EMBEDDING_TEXT_TYPE=document

# ---- Reranker API（阿里云百炼原生格式）----
RERANK_PROVIDER=dashscope
RERANK_API_KEY=
RERANK_MODEL=qwen3-rerank
RERANK_ENABLED=true
# 可选：限制返回前 N 条（默认空=返回服务端全部排序结果）
# RERANK_TOP_N=5
# 可选：百炼 qwen3-rerank 的 instruct 参数
# RERANK_INSTRUCT=Given a web search query, retrieve relevant passages that answer the query.

# ---- 数据目录（容器内路径）----
CHROMA_DIR=/data/chroma
NOTES_DIR=/data/notes
DOCSTORE_PATH=/data/docstore.json
DB_PATH=/data/blog.db
# NOTES_ASSETS_FOLDERS：附件文件夹名（逗号分隔），这些文件夹不会被索引为博客文章
# 但仍会被同步下载和 Quartz 构建复制，保证文章中的图片正常显示
NOTES_ASSETS_FOLDERS=assets
DB_PATH=/data/blog.db

# ---- Chroma 集合名 ----
CHROMA_COLLECTION=blog

# ---- 检索参数 ----
SIMILARITY_TOP_K=5

# ---- 上游请求容错 ----
LLM_TIMEOUT_SECONDS=60
EMBEDDING_TIMEOUT_SECONDS=60
RERANK_TIMEOUT_SECONDS=60
HTTP_MAX_RETRIES=2
HTTP_RETRY_BACKOFF_SECONDS=1
EMBEDDING_BATCH_SIZE=10

# ---- 联调开关：true 时 llm_client 返回固定文本，不调真实 API（控费/前端联调用）----
LLM_MOCK=false

# ---- /api/reindex 简单保护 token（留空则该接口拒绝公网调用）----
REINDEX_TOKEN=

# ---- /admin/api 管理后台保护 token（留空则管理接口拒绝调用）----
ADMIN_TOKEN=

# ---- 阶段五自动化（宿主机脚本使用，不是容器内路径）----
# 真实 SecretId / SecretKey 只保存在服务器本地 .env 或本地 coscli 配置文件中，不写进仓库。
COSCLI_BIN=coscli
# 方式一：直接在 .env 中提供 COS 凭证与桶信息，sync.sh 会临时生成 coscli 配置。
# sync.sh 仅允许 COS -> 本地 data/notes 的单向拉取；同名文件以远端覆盖本地，不支持本地上传到 COS。
# 若本地存在远端已删除的文件，会移动到 data/logs/cos-sync-backup/ 作为删除备份。
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-shanghai
COS_ENDPOINT=cos.ap-shanghai.myqcloud.com
COS_BUCKET=your-bucket-1234567890
# NOTES_COS_PREFIX：OSS 中存放博客笔记的文件夹路径（不含桶名和 cos:// 前缀）
# sync.sh 会根据 COS_BUCKET + NOTES_COS_PREFIX 自动拼出完整同步源
# 留空则回退到 COS_SYNC_SOURCE（完整路径）或报错
NOTES_COS_PREFIX=Obsidian/Blog/online
# 方式一（旧）：直接指定完整 COS 同步源路径。若已配置 NOTES_COS_PREFIX 则优先使用拼接结果
# COS_SYNC_SOURCE=cos://your-bucket-1234567890/Obsidian/Blog/online/
# 方式二：如果你已经手工配置了 coscli，也可以直接指定现有配置文件路径。
# COSCLI_CONFIG_PATH=/home/ubuntu/.config/coscli/config.yaml
# 可选：若 nginx 不是默认的 http://127.0.0.1，可显式覆盖脚本访问地址。
API_BASE=http://127.0.0.1:18088
# 可选：脚本超时与轮询参数（按需打开）。
# SCRIPT_HTTP_CONNECT_TIMEOUT_SECONDS=5
# SCRIPT_HEALTH_MAX_TIME_SECONDS=15
# SCRIPT_REINDEX_MAX_TIME_SECONDS=1800
# SCRIPT_ROOT_MAX_TIME_SECONDS=15
# DEPLOY_HEALTH_RETRIES=60
# DEPLOY_HEALTH_INTERVAL_SECONDS=2
# DEPLOY_BUILD_RETRIES=300
# DEPLOY_BUILD_INTERVAL_SECONDS=2

# ---- CORS 放行的博客域名（多个用逗号分隔；开发期可填 http://localhost）----
ALLOWED_ORIGINS=http://localhost
