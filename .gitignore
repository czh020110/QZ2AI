.claude/
.claude_introduction/

# 密钥：真实 .env 只在服务器，绝不进仓库
.env
*.env
!.env.example

# 运行时数据：与代码分离，单独挂载
/data/notes/
data/chroma/*
data/logs/*
data/docstore.json
data/blog.db
data/sync-pending.json
data/appearance.json
data/content_visibility.json
data/public_content_manifest.json
data/assets/*
!data/chroma/.gitkeep
!data/logs/.gitkeep

# Python
apps/api/__pycache__/
apps/api/**/__pycache__/
*.pyc
.venv/
venv/

# Node / Quartz
apps/web/node_modules/
apps/web/public/
apps/web/.quartz-cache/

# 杂项
*.log
.DS_Store

# Quartz 上游 vendor 模板配置，非实际使用的配置
apps/web/_vendor_quartz/quartz.config.yaml
